{
  "info": {
    "name": "Sistema de Chamados API",
    "description": "Coleção de endpoints da API do Sistema de Chamados",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@local\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chamados",
      "item": [
        {
          "name": "Listar Chamados",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": ["{{base_url}}"],
              "path": ["tickets"]
            }
          },
          "response": []
        },
        {
          "name": "Criar Chamado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Problema no sistema\",\n  \"description\": \"Descrição detalhada do problema\",\n  \"category_id\": 1,\n  \"priority\": \"medium\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": ["{{base_url}}"],
              "path": ["tickets"]
            }
          },
          "response": []
        },
        {
          "name": "Visualizar Chamado",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tickets/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Atualizar Chamado",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Problema no sistema - Atualizado\",\n  \"description\": \"Descrição atualizada do problema\",\n  \"category_id\": 1,\n  \"priority\": \"high\",\n  \"status\": \"in_progress\",\n  \"assignee_id\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Excluir Chamado",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tickets/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Comentários",
      "item": [
        {
          "name": "Adicionar Comentário",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Comentário sobre o chamado\",\n  \"is_internal\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets/1/comments",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1", "comments"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Anexos",
      "item": [
        {
          "name": "Adicionar Anexo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "attachment",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/tickets/1/attachments",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1", "attachments"]
            }
          },
          "response": []
        },
        {
          "name": "Baixar Anexo",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tickets/1/attachments/1/download",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1", "attachments", "1", "download"]
            }
          },
          "response": []
        },
        {
          "name": "Excluir Anexo",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tickets/1/attachments/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1", "attachments", "1"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dados de Apoio",
      "item": [
        {
          "name": "Listar Categorias",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"]
            }
          },
          "response": []
        },
        {
          "name": "Listar SLAs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/slas",
              "host": ["{{base_url}}"],
              "path": ["slas"]
            }
          },
          "response": []
        },
        {
          "name": "Listar Usuários",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}











